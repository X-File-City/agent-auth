    "fail_sub_over_budget": {
      "action": "write",
      "agent": "sub_delegate",
      "args": {
        "cost": 150,
        "topic": "too expensive"
      },
      "expected": "fail",
      "expected_reason": "max_cost"
    },
    "fail_sub_wrong_scope": {
      "action": "edit",
      "agent": "sub_delegate",
      "args": {
        "cost": 10,
        "topic": "not allowed"
      },
      "expected": "fail",
      "expected_reason": "action_scope"
    },
    "fail_wrong_scope": {
      "action": "spend",
      "agent": "delegate",
      "args": {
        "cost": 50,
        "platform": "ads"
      },
      "expected": "fail",
      "expected_reason": "action_scope"
    },
    "pass_in_scope": {
      "action": "write",
      "agent": "delegate",
      "args": {
        "cost": 50,
        "topic": "blog post"
      },
      "expected": "pass",
      "expected_depth": 1
    },
    "pass_sub_delegate": {
      "action": "write",
      "agent": "sub_delegate",
      "args": {
        "cost": 75,
        "topic": "draft"
      },
      "expected": "pass",
      "expected_depth": 2
    }
  }
